# Virtual Environment
.venv/
venv/
ENV/
env/

# Python Cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Reports / Outputs
laporan/
downloads/
logs/
*.csv
*.xlsx

# Credentials & Secrets
.env
*credentials*.json
data/*_cache.csv

# Browser Profiles & Sessions Caches (Profiles & Sessions themselves are allowed)
